{
  "name": "electron-demo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "electron-dist/main.cjs",
  "scripts": {
    "dev": "vite",
    "electron": "electron .",
    "start": "concurrently \"vite\" \"wait-on http://localhost:3000 && electron .\"",
    "build": "tsc -b && vite build",
    "build:all": "npm run build && npm run build:electron",
    "dist": "npm run build && npm run build:electron && electron-builder",
    "dist:publish": "npm run build && npm run build:electron && electron-builder --publish always",
    "build:electron": "tsc -p tsconfig.electron.json && mv electron-dist/main.js electron-dist/main.cjs",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.electron.demo",
    "productName": "ElectronDemo",
    "files": [
      "dist/**/*",
      "electron-dist/**/*",
      "package.json"
    ],
    "extraMetadata": {
      "main": "electron-dist/main.cjs"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^10.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/electron": "^1.4.38",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "babel-plugin-react-compiler": "^1.0.0",
    "chokidar": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "electron-reload": "^2.0.0-alpha.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.10",
    "wait-on": "^9.0.5"
  }
}