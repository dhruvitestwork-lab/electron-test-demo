{
  "appId": "com.electron.demo",
  "productName": "ElectronDemo",
  "directories": {
    "output": "release"
  },
  "extraMetadata": {
    "main": "electron-dist/main.cjs"
  },
  "files": [
    "dist/**/*",
    "electron-dist/**/*",
    "package.json"
  ],
  "mac": {
    "category": "public.app-category.productivity",
    "target": [
      {
        "target": "dmg",
        "arch": [
          "x64",
          "arm64"
        ]
      },
      {
        "target": "zip",
        "arch": [
          "x64",
          "arm64"
        ]
      }
    ]
  },
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": [
          "x64"
        ]
      }
    ]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true
  },
  "publish": {
    "provider": "github",
    "owner": "dhruvitestwork-lab",
    "repo": "electron-test-demo",
    "private": false
  }
}